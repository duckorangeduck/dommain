<style is:global>
    @import url("https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600&display=swap");

    :root {
        --bg: #17191e;
        --text: #c9cdd6;
        --text-muted: #858b98;
        --text-heading: #e4e7ed;
        --accent: #4af2c8;
        --font-sans:
            "Nunito", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: var(--font-sans);
        background-color: var(--bg);
        color: var(--text);
        line-height: 1.7;
        font-size: 16px;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    main {
        max-width: 640px;
        margin: 0 auto;
        padding: 6rem 1.5rem 4rem;
    }

    header {
        margin-bottom: 3rem;
    }

    .photo {
        width: 100%;
        max-width: 220px;
        border-radius: 8px;
        margin-top: 1.5rem;
    }

    h1 {
        font-size: 2.75rem;
        font-weight: 600;
        color: var(--text-heading);
        letter-spacing: -0.03em;
        line-height: 1.2;
        margin-bottom: 0.75rem;
    }

    .tagline {
        font-size: 1.3rem;
        color: var(--text-muted);
        line-height: 1.6;
    }

    .bio {
        margin-top: 0.9rem;
        font-size: 1.1rem;
        color: var(--text-muted);
        line-height: 1.7;
    }

    h2 {
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 1.25rem;
    }

    .link-list {
        list-style: none;
    }

    .link-list li {
        margin-bottom: 0.5rem;
    }

    .link-list a {
        color: var(--text);
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.2s;
    }

    .link-list a:hover {
        color: var(--accent);
    }

    @media (max-width: 480px) {
        main {
            padding-top: 3rem;
        }

        h1 {
            font-size: 1.75rem;
        }
    }
</style>
