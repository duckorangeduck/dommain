                        x2="12"
                        y2="4"
                        transform="rotate(225 12 12)"></line>
                    <line
                        x1="12"
                        y1="1"
                        x2="12"
                        y2="4"
                        transform="rotate(270 12 12)"></line>
                    <line
                        x1="12"
                        y1="1"
                        x2="12"
                        y2="4"
                        transform="rotate(315 12 12)"></line>
                </g>
            </svg>
        </button>

        <main>
            <header>
                <h1>Dom Main</h1>
                <p class="tagline">
                    I build practical tools for real problems, with AI and code.
                </p>
                <p class="bio">
                    Currently running a team who make AI tech for GP practices.
                    I'm a self-taught engineer, experienced PM and (thankfully)
                    a properly taught doctor. My background in medicine shapes
                    how I think about people, problems, and good technology.
                </p>
                <img src="/ohlookitsdom.jpg" alt="Dom Main" class="photo" />
            </header>

            <section>
                <h2>Let's be friends</h2>
                <ul class="link-list">
                    <li>
                        <a href="mailto:hello@dommain.net">hello@dommain.net</a>
                    </li>
                    <li>
                        <a href="https://github.com/duckorangeduck"
                            >GitHub &rarr;</a
                        >
                    </li>
                </ul>
            </section>
        </main>
    </body>
</html>

